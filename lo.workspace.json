        "packages/lo-compute",
        "packages/lo-photonic",
        "packages/lo-target-binary",
        "packages/lo-target-wasm",
        "packages/lo-target-gpu",
        "packages/lo-target-photonic",
        "packages/lo-app-kernel",
        "packages/lo-api-server",
        "packages/lo-cli",
        "packages/lo-tasks",
        "packages/app"
