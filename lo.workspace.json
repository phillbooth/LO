        "logic": "packages/lo-logic",
        "vector": "packages/lo-vector",
        "compute": "packages/lo-compute",
        "photonic": "packages/lo-photonic",
        "targetBinary": "packages/lo-target-binary",
        "targetWasm": "packages/lo-target-wasm",
        "targetGpu": "packages/lo-target-gpu",
        "targetPhotonic": "packages/lo-target-photonic",
        "runtimeKernel": "packages/lo-app-kernel",
        "cliAndTasks": "packages/lo-cli-and-lo-tasks-requirements.md"
