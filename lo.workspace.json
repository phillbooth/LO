    "defaultPackage": "packages/app",
    "languagePackage": "packages/lo-core",
    "compilerPackage": "packages/lo-compiler",
    "runtimePackage": "packages/lo-runtime",
    "securityPackage": "packages/lo-security",
    "configPackage": "packages/lo-config",
    "reportsPackage": "packages/lo-reports",
    "logicPackage": "packages/lo-logic",
